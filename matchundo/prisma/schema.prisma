datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Screening {
  id                String   @id @default(uuid()) @db.Uuid
  matchName         String   @map("match_name")
  venueName         String   @map("venue_name")
  city              String
  address           String
  screeningDatetime DateTime @map("screening_datetime")
  description       String?
  posterImageUrl    String?  @map("poster_image_url")
  googleMapsLink    String?  @map("google_maps_link")
  createdAt         DateTime @default(now()) @map("created_at")
  
  // Submission & Moderation fields
  status            String   @default("approved") // pending, approved, rejected
  submittedByName   String?  @map("submitted_by_name")
  submittedByEmail  String?  @map("submitted_by_email")
  reviewedAt        DateTime? @map("reviewed_at")
  reviewedBy        String?  @map("reviewed_by")
  
  sport             String?
  competition       String?
  notifyByEmail     Boolean  @default(true) @map("notify_by_email")
  reports           Report[]
  shareEvents       ShareEvent[]

  @@map("screenings")
}

model Report {
  id          String    @id @default(uuid()) @db.Uuid
  screeningId String    @map("screening_id") @db.Uuid
  reason      String
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  status      String    @default("pending") // pending, resolved

  screening   Screening @relation(fields: [screeningId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model ModerationEvent {
  id          String   @id @default(uuid()) @db.Uuid
  screeningId String   @map("screening_id") @db.Uuid
  action      String   // submission_created, submission_approved, submission_rejected
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("moderation_events")
}

model ShareEvent {
  id          String   @id @default(uuid()) @db.Uuid
  screeningId String   @map("screening_id") @db.Uuid
  shareType   String   @map("share_type") // copy_link, whatsapp_share, native_share, telegram_share, instagram_share
  createdAt   DateTime @default(now()) @map("created_at")

  screening   Screening @relation(fields: [screeningId], references: [id], onDelete: Cascade)

  @@map("share_events")
}

